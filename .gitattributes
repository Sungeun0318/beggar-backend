# 기본: 자동 텍스트 판별 + LF로 정규화
* text=auto eol=lf

# Java / Kotlin / Gradle 등 코드는 LF 강제
*.java       text eol=lf
*.kt         text eol=lf
*.gradle     text eol=lf
*.properties text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.xml        text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.sql        text eol=lf
*.sh         text eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.bat        text eol=crlf
*.cmd        text eol=crlf

# Gradle wrapper
gradlew      text eol=lf
gradlew.bat  text eol=crlf

# 바이너리는 diff 안 보이게
*.jar     binary
*.war     binary
*.class   binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.zip     binary
*.tar     binary
*.gz      binary
*.pdf     binary
*.keystore binary
*.jks     binary
*.p12     binary
